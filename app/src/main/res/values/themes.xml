<resources>
    <!-- Base application theme. -->
    <style name="Theme.SecuritiesExam" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/theme_cyan</item>
        <!--        這一行是沒有用的，即使設定它，還是會使用預設的colorPrimaryVariant-->
        <!--        <item name="colorPrimaryVariant">@color/handle_bar_color</item>-->
        <item name="colorOnPrimary">@color/theme_light</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/theme_cyan</item>
        <item name="colorSecondaryVariant">@color/theme_cyan_light</item>
        <item name="colorOnSecondary">@color/theme_dark</item>
        <!-- Status bar color. -->
        <item name="android:windowLightStatusBar">true</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="CustomBottomSheetDialogTheme" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

</resources>